{
  "name": "pandoc-wasm",
  "version": "1.0.0",
  "description": "Pandoc CLI compiled to WebAssembly - works in Node.js, Deno, Bun, and browsers",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs",
      "types": "./dist/pandoc-server.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.mjs",
      "types": "./dist/browser.d.ts"
    }
  },
  "bin": {
    "pandoc-wasm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "npm run build",
    "demo": "cd demo && npm run dev"
  },
  "keywords": [
    "pandoc",
    "wasm",
    "webassembly",
    "markdown",
    "document",
    "converter",
    "cli"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/pandoc-wasm-cli.git"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.17",
    "rollup": "^4.12.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.3.0",
    "commander": "^12.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}